{
  "name": "@goderash/sdk",
  "version": "0.1.1",
  "description": "Goderash SDK — audit any AI agent with one import. Tamper-evident, hash-chained, regulator-ready.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "src", "README.md"],
  "keywords": [
    "ai",
    "ai-agent",
    "agents",
    "audit",
    "compliance",
    "governance",
    "soc2",
    "hipaa",
    "ffiec",
    "finra",
    "ledger",
    "observability",
    "llm",
    "llmops",
    "mlops",
    "tool-calling",
    "agent-framework",
    "anthropic",
    "openai",
    "langchain",
    "langgraph"
  ],
  "homepage": "https://ai.goderash.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goderash/goderash.git",
    "directory": "packages/sdk-ts"
  },
  "bugs": {
    "url": "https://github.com/goderash/goderash/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome lint src || true",
    "format": "biome format --write src || true"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
