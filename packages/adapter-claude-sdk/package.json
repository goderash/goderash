{
  "name": "@goderash/adapter-claude-sdk",
  "version": "0.1.0",
  "description": "Audit handler for the Anthropic Claude TypeScript SDK and Claude Agent SDK",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
