  "dependencies": {
    "@goderash/sdk": "workspace:*"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.30.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
