# ---- Core control plane ----
GODERASH_ENV=dev                                      # dev | staging | prod
GODERASH_LOG_LEVEL=INFO
GODERASH_API_HOST=0.0.0.0
GODERASH_API_PORT=8000

# ---- Security (required) ----
JWT_SECRET=change-me-at-least-32-characters-long-12
API_KEY_PREFIX=gdr_
ADMIN_API_KEY=gdr_admin_change_me

# ---- Database ----
DATABASE_URL=postgresql+asyncpg://goderash:goderash@localhost:5432/goderash
DATABASE_POOL_SIZE=20
DATABASE_POOL_MAX_OVERFLOW=10

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000

# ---- Observability (optional) ----
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
PROMETHEUS_ENABLED=true
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=

# ---- Compliance packs ----
PACK_SIGNING_KEY_PATH=./secrets/pack-signing.key
PACK_OUTPUT_DIR=./data/packs

# ---- Multi-tenant ----
DEFAULT_TENANT=goderash-internal
ENFORCE_TENANT_ISOLATION=true

# ---- Ingestion limits ----
MAX_EVENT_BATCH_SIZE=500
MAX_EVENT_PAYLOAD_BYTES=65536
INGEST_RATE_LIMIT_PER_MINUTE=6000

# ---- SDK (set when running examples) ----
GODERASH_API_KEY=gdr_demo_...
GODERASH_TENANT=demo
GODERASH_ENDPOINT=http://localhost:8000
